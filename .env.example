PEXELS_API_KEY= # crucial for the project to work
LOG_LEVEL=trace # trace, debug, info, warn, error, fatal, silent
WHISPER_VERBOSE=true
PORT=3123
DEV=true # local development mode
DATA_DIR_PATH= # only for docker, otherwise leave empty

# ── Phase 4: Redis / BullMQ ─────────────────────────────────────────────────
REDIS_ENABLED=false          # set to true when Redis is running
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=              # leave empty if no auth
RENDER_WORKER_CONCURRENCY=1  # phase 4.9 scaling
PUBLISH_WORKER_CONCURRENCY=3 # phase 4.9 scaling

# ── Phase 5: Platform Publishers ────────────────────────────────────────────
# YouTube (OAuth2 – offline access)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=       # obtain via OAuth consent screen

# Telegram Bot API
TELEGRAM_BOT_TOKEN=          # from @BotFather
TELEGRAM_CHANNEL_ID=         # e.g. @mychannel or -1001234567890

# Instagram Graph API (requires Business App approval)
INSTAGRAM_ACCESS_TOKEN=

# Facebook Graph API (requires Page Access Token)
FACEBOOK_ACCESS_TOKEN=

# Alerting
SLACK_WEBHOOK_URL=
PAGERDUTY_ROUTING_KEY=
ALERT_EMAIL_TO=

# ── Phase 6: Scheduler ───────────────────────────────────────────────────────
CRON_INTERVAL=*/30 * * * *   # how often to check for new content (cron syntax)

# ── AI LLM (metadata generation) ────────────────────────────────────────────
AI_LLM_URL=http://localhost:12434
AI_LLM_MODEL=docker.io/ai/llama3.2:latest

# Phase 7: Multi-tenant security
TENANT_KEYS_SECRET=change-me-in-production
